OPENAI_API_KEY=
OPENAI_BASE_URL=
MODEL_NAME=gpt-4o-mini

# Database Configuration
# For local development (SQLite):
# DATABASE_URL=sqlite:///./strategy_council.db
# For production (PostgreSQL - Neon, Supabase, or Vercel Postgres):
# DATABASE_URL=postgresql://user:password@host/database
DATABASE_URL=sqlite:///./strategy_council.db

EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
WORDPRESS_LOGGED_IN_COOKIE=

# CORS Configuration
# Set this to your frontend URL(s) in production
# Multiple origins can be comma-separated
# Example: CORS_ORIGINS_RAW=https://your-app.vercel.app,http://localhost:3000
CORS_ORIGINS_RAW=
